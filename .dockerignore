# Docker 빌드 시 제외할 파일 목록
# .gitignore와 유사하지만 Docker 빌드 컨텍스트용

# 의존성 (컨테이너 내부에서 설치)
node_modules
npm-debug.log*

# Next.js 빌드 결과물
.next
out

# 환경변수 (런타임에 주입)
.env
.env.local
.env.*.local

# Git
.git
.gitignore

# IDE
.idea
.vscode
*.iml

# 문서
README.md
docs/

# 테스트
coverage/
*.test.ts
*.test.tsx

# OS
.DS_Store
Thumbs.db
